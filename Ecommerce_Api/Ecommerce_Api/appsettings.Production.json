{
  "Razorpay": {
    "KeyId": "REPLACE_WITH_LIVE_KEY_ID",
    "KeySecret": "REPLACE_WITH_LIVE_KEY_SECRET"
  },

  "ConnectionStrings": {
    "DataContextConnection": "REPLACE_WITH_PRODUCTION_CONNECTION_STRING"
  },

  "Jwt": {
    "Key": "REPLACE_WITH_STRONG_PRODUCTION_KEY_MIN_32_CHARS",
    "Issuer": "https://your-production-domain.com",
