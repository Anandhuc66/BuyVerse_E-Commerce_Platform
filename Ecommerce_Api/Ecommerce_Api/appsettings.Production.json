    "Password": "REPLACE_WITH_STRONG_ADMIN_PASSWORD"
  },

  "Cors": {
    "AllowedOrigins": [ "https://your-production-domain.com" ]
  },

  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "AllowedHosts": "*"
